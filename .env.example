# Shared database used by both account-service and game-server.
CANARY_DB_HOST=YOUR_DB_HOST
CANARY_DB_PORT=3306
CANARY_DB_NAME=YOUR_DB_NAME
CANARY_DB_USER=YOUR_DB_USER
CANARY_DB_PASSWORD=YOUR_DB_PASSWORD

# Game server identity and ports.
CANARY_SERVER_NAME=YOUR_SERVER_NAME
CANARY_SERVER_IP=YOUR_SERVER_IP
CANARY_SERVER_LOCATION=YOUR_SERVER_LOCATION
CANARY_LOGIN_PORT=7171
CANARY_GAME_PORT=7172
CANARY_STATUS_PORT=7173
CANARY_STATUS_TIMEOUT=5000

# Datapack folder bundled in the repository image.
CANARY_DATA_PACK=data-otservbr-global

# Optional legacy world ports. Leave at 0 unless you need those clients.
CANARY_LEGACY_1100_GAME_PORT=0
CANARY_LEGACY_860_GAME_PORT=0
